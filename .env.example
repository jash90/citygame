# ═══════════════════════════════════════════════════════════════════════════════
# CityGame — Root Environment Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file lists ALL environment variables needed across the monorepo.
# Copy per-app .env.example files for actual development:
#
#   cp apps/backend/.env.example apps/backend/.env
#   cp apps/admin/.env.example apps/admin/.env.local
#   cp apps/mobile/.env.example apps/mobile/.env
#
# Quick start:
#   docker compose -f docker/docker-compose.yml up -d   # Postgres + Redis
#   pnpm install
#   cd apps/backend && npx prisma migrate dev && npx prisma generate
#   pnpm dev:backend   # port 3001
#   pnpm dev:admin     # port 3002
#   pnpm dev:mobile    # Expo dev client
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend (apps/backend/.env) ───────────────────────────────────────────────
DATABASE_URL="postgresql://citygame:citygame_dev@localhost:5433/citygame"
REDIS_URL="redis://localhost:6380"
# Ports 5433/6380 match docker/docker-compose.yml host mappings.
# Use 5432/6379 if running Postgres/Redis natively without Docker.

JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-5"
AI_TIMEOUT_MS=30000

R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY=""
R2_SECRET_KEY=""
R2_BUCKET="citygame-assets"
R2_PUBLIC_URL=""

CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
PORT=3001

# ── Admin (apps/admin/.env.local) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Mobile (apps/mobile/.env) ────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001/api
EXPO_PUBLIC_WS_URL=http://localhost:3001
