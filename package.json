{
  "name": "citygame",
  "private": true,
  "scripts": {
    "dev:backend": "turbo run dev --filter=@citygame/backend",
    "dev:admin": "turbo run dev --filter=@citygame/admin",
    "dev:mobile": "turbo run dev --filter=@citygame/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "turbo run db:migrate --filter=@citygame/backend",
    "db:generate": "turbo run db:generate --filter=@citygame/backend",
    "db:seed": "turbo run db:seed --filter=@citygame/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
