---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="grid">
      <div>
        <div class="brand">
          <div class="brand-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <span>CityGame</span>
        </div>
        <p class="tagline">
          Platforma do miejskich gier przygodowych.
          Odkrywaj miasta w zupełnie nowy sposób.
        </p>
      </div>

      <div>
        <h4>Nawigacja</h4>
        <ul>
          <li><a href="#funkcje">Funkcje</a></li>
          <li><a href="#jak-to-dziala">Jak to działa</a></li>
          <li><a href="#pobierz">Pobierz</a></li>
        </ul>
      </div>

      <div>
        <h4>Informacje</h4>
        <ul>
          <li><a href="/privacy">Polityka prywatności</a></li>
          <li><a href="/terms">Regulamin</a></li>
          <li><span>kontakt@citygame.pl</span></li>
        </ul>
      </div>
    </div>

    <div class="bottom">
      <p>{currentYear} CityGame. Wszelkie prawa zastrzeżone.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0d0d1a;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    background: #FF6B35;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .brand span {
    color: white;
    font-weight: 700;
    font-size: 1.125rem;
  }

  .tagline {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  h4 {
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  ul a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  ul a:hover { color: rgba(255, 255, 255, 0.7); }

  ul span {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.875rem;
  }

  .bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
  }

  .bottom p {
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.75rem;
  }

  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
