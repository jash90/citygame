---
import PhoneMockup from './PhoneMockup.astro';

const phases = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>',
    title: 'Prolog i fabuła',
    description: 'Każda gra narracyjna zaczyna się od wciągającej historii, która wprowadza Cię w klimat przygody. Odczytaj wskazówki i odkryj tajemnice miasta.',
    screenshot: '/screenshots/narrative-task.png',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8c0 4.5-6 9-6 9s-6-4.5-6-9a6 6 0 0 1 12 0"/><circle cx="12" cy="8" r="2"/><path d="M8.835 14H5a1 1 0 0 0-.9.7l-2 6c-.1.1-.1.2-.1.3 0 .6.4 1 1 1h18c.6 0 1-.4 1-1 0-.1 0-.2-.1-.3l-2-6a1 1 0 0 0-.9-.7h-3.835"/></svg>',
    title: 'Eksploracja na mapie',
    description: 'Odkrywaj punkty na mapie miasta. Każdy pin to zadanie czekające na realizację. Podążaj za wskazówkami GPS w terenie.',
    screenshot: '/screenshots/interactive-map.png',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>',
    title: 'Realizacja zadań',
    description: 'Odpowiadaj na pytania, skanuj kody QR, rób zdjęcia — każde zadanie to nowe wyzwanie. Zdobywaj punkty za każde wykonane zadanie.',
    screenshot: '/screenshots/task-list.png',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>',
    title: 'Punkty i ranking',
    description: 'Zdobywaj punkty za każde wykonane zadanie. Sprawdź swoją pozycję w rankingu w czasie rzeczywistym i rywalizuj z innymi.',
    screenshot: '/screenshots/ranking.png',
  },
];
---

<section id="przebieg-gry" class="showcase">
  <div class="container">
    <div class="header" data-reveal>
      <p class="label">Przebieg gry</p>
      <h2>Jak wygląda sesja gry</h2>
      <p class="description">
        Od startu do mety — każda gra to unikalna przygoda pełna zadań i odkryć.
      </p>
    </div>

    <div class="phases">
      {phases.map((phase, index) => (
        <div class="phase-row" data-reveal data-reveal-delay={index * 150}>
          <div class="phase-text">
            <div class="phase-header">
              <div class="phase-icon">
                <Fragment set:html={phase.icon} />
              </div>
              <span class="phase-number">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <h3>{phase.title}</h3>
            <p>{phase.description}</p>
          </div>
          <div class="phase-visual">
            <PhoneMockup src={phase.screenshot} alt={phase.title} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase {
    padding: 5rem 0;
    background: white;
    position: relative;
  }

  .showcase::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 107, 53, 0.15), transparent);
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .label {
    color: #FF6B35;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  h2 {
    font-size: 1.875rem;
    font-weight: 800;
    color: #1a1a2e;
  }

  .description {
    color: #6b7280;
    margin-top: 1rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .phases {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .phase-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    border-radius: 1.5rem;
    background: #f9fafb;
    border: 1px solid #f3f4f6;
  }

  .phase-text {
    flex: 1;
  }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .phase-icon {
    width: 3rem;
    height: 3rem;
    background: #1a1a2e;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FF6B35;
    flex-shrink: 0;
  }

  .phase-number {
    font-size: 0.75rem;
    font-weight: 700;
    color: #FF6B35;
    background: rgba(255, 107, 53, 0.1);
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
  }

  h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .phase-text p {
    color: #6b7280;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .phase-visual {
    display: flex;
    justify-content: center;
    flex-shrink: 0;
  }

  .phase-visual :global(.phone-frame) {
    width: 150px;
  }

  @media (min-width: 640px) {
    .showcase { padding: 7rem 0; }
    h2 { font-size: 2.25rem; }

    .phase-visual :global(.phone-frame) {
      width: 160px;
    }
  }

  @media (min-width: 768px) {
    .phase-row {
      flex-direction: row;
      gap: 3rem;
      padding: 2.5rem;
    }

    .phase-row:nth-child(even) {
      flex-direction: row-reverse;
    }

    .phase-visual :global(.phone-frame) {
      width: 170px;
    }
  }

  @media (min-width: 1024px) {
    .phases { gap: 2rem; }

    .phase-row {
      padding: 3rem;
    }

    .phase-visual :global(.phone-frame) {
      width: 190px;
    }

    h3 { font-size: 1.5rem; }
  }
</style>
