---
import PhoneMockup from './PhoneMockup.astro';
---

<section class="hero">
  <div class="bg-glow">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="glow glow-3"></div>
  </div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="badge">
        <div class="badge-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <span>CityGame</span>
      </div>

      <h1>Odkrywaj miasta<br /><span class="accent">przez grę</span></h1>

      <p class="subtitle">
        Dołącz do miejskich gier przygodowych. Eksploruj ukryte zakątki,
        rozwiązuj zagadki, zbieraj wskazówki i rywalizuj z innymi graczami
        w Twoim mieście.
      </p>

      <div class="actions">
        <a href="#pobierz" class="btn-primary">Rozpocznij przygodę</a>
        <a href="#funkcje" class="btn-secondary">Dowiedz się więcej</a>
      </div>

      <div class="stats">
        <div>
          <div class="stat-value">100+</div>
          <div class="stat-label">Graczy</div>
        </div>
        <div>
          <div class="stat-value">15+</div>
          <div class="stat-label">Gier miejskich</div>
        </div>
        <div>
          <div class="stat-value">5</div>
          <div class="stat-label">Miast</div>
        </div>
      </div>
    </div>

    <div class="hero-phones">
      <div class="phone-back">
        <PhoneMockup src="/screenshots/game-selection.png" alt="Wybierz grę miejską" eager />
      </div>
      <div class="phone-front">
        <PhoneMockup src="/screenshots/interactive-map.png" alt="Interaktywna mapa z zadaniami" eager />
      </div>
    </div>
  </div>

  <a href="#funkcje" class="scroll-indicator" aria-label="Przewiń w dół">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(255, 107, 53, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(255, 107, 53, 0.05) 0%, transparent 40%),
      linear-gradient(135deg, #1a1a2e 0%, #16162a 40%, #1a1a2e 60%, #1e1e35 100%);
  }

  .bg-glow {
    position: absolute;
    inset: 0;
    opacity: 0.12;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    background: #FF6B35;
  }

  .glow-1 { top: 5rem; left: 2.5rem; width: 18rem; height: 18rem; filter: blur(128px); }
  .glow-2 { bottom: 5rem; right: 2.5rem; width: 24rem; height: 24rem; filter: blur(160px); }
  .glow-3 { top: 50%; right: 20%; width: 20rem; height: 20rem; filter: blur(140px); opacity: 0.5; }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 72rem;
    width: 100%;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    padding: 0.625rem 1.25rem;
    margin-bottom: 2rem;
  }

  .badge-icon {
    width: 2rem;
    height: 2rem;
    background: #FF6B35;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .badge span {
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .accent { color: #FF6B35; }

  .subtitle {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 40rem;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #FF6B35;
    color: white;
    font-weight: 700;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: #e55a26;
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    color: white;
    font-weight: 600;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: background 0.2s;
  }

  .btn-secondary:hover { background: rgba(255, 255, 255, 0.15); }

  .stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .stat-value {
    font-size: 1.875rem;
    font-weight: 800;
    color: white;
  }

  .stat-label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.25rem;
  }

  /* Phone mockups */
  .hero-phones {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 16rem;
  }

  .phone-front {
    position: relative;
    z-index: 2;
    animation: float 4s ease-in-out infinite;
  }

  .phone-front :global(.phone-frame) {
    width: 180px;
  }

  .phone-back {
    display: none;
    position: absolute;
    z-index: 1;
  }

  .phone-back :global(.phone-frame) {
    width: 160px;
    opacity: 0.7;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.4);
    transition: color 0.2s;
    animation: bounce 2s infinite;
  }

  .scroll-indicator:hover { color: rgba(255, 255, 255, 0.7); }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-8px); }
  }

  /* Tablet */
  @media (min-width: 640px) {
    h1 { font-size: 3.25rem; }
    .subtitle { font-size: 1.25rem; }
    .actions { flex-direction: row; }
    .stats { gap: 4rem; }

    .hero-phones {
      max-width: 22rem;
    }

    .phone-front :global(.phone-frame) {
      width: 200px;
    }

    .phone-back {
      display: block;
      left: -1.5rem;
      top: 1.5rem;
      transform: rotate(-8deg);
    }

    .phone-back :global(.phone-frame) {
      width: 180px;
    }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .hero-content {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
      padding: 0 2rem;
    }

    .hero-text {
      flex: 1;
      text-align: left;
    }

    h1 { font-size: 4rem; }

    .subtitle {
      margin-left: 0;
      margin-right: 0;
    }

    .actions {
      justify-content: flex-start;
    }

    .stats {
      justify-content: flex-start;
    }

    .hero-phones {
      flex: 0 0 auto;
      max-width: none;
      width: auto;
    }

    .phone-front :global(.phone-frame) {
      width: 230px;
    }

    .phone-back {
      display: block;
      left: -2.5rem;
      top: 2rem;
      transform: rotate(-8deg);
    }

    .phone-back :global(.phone-frame) {
      width: 200px;
    }
  }

  @media (min-width: 1280px) {
    h1 { font-size: 4.5rem; }

    .phone-front :global(.phone-frame) {
      width: 260px;
    }

    .phone-back :global(.phone-frame) {
      width: 230px;
    }
  }
</style>
