---
import PhoneMockup from './PhoneMockup.astro';
---

<section id="pobierz" class="cta">
  <div class="bg-glow"></div>
  <div class="bg-glow-2"></div>

  <div class="content">
    <div class="cta-text" data-reveal>
      <div class="icon-box">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>

      <h2>Gotowy na miejską przygodę?</h2>
      <p class="subtitle">
        Pobierz aplikację CityGame i dołącz do gier w swoim mieście.
        Nowe przygody czekają na Ciebie.
      </p>

      <div class="buttons">
        <a href="#" class="btn-appstore">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
          App Store
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#" class="btn-google">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
          Google Play
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <p class="note">Wkrótce dostępne na obu platformach</p>
    </div>

    <div class="cta-phones" data-reveal data-reveal-delay="200">
      <div class="phone-back-cta">
        <PhoneMockup src="/screenshots/game-selection.png" alt="Wybierz grę" />
      </div>
      <div class="phone-front-cta">
        <PhoneMockup src="/screenshots/profile.png" alt="Profil gracza" />
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 5rem 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(255, 107, 53, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 30%, rgba(255, 107, 53, 0.05) 0%, transparent 40%),
      linear-gradient(135deg, #1a1a2e 0%, #16162a 50%, #1e1e35 100%);
    position: relative;
    overflow: hidden;
  }

  .bg-glow {
    position: absolute;
    top: 50%;
    left: 30%;
    transform: translate(-50%, -50%);
    width: 37.5rem;
    height: 37.5rem;
    border-radius: 50%;
    background: rgba(255, 107, 53, 0.06);
    filter: blur(100px);
  }

  .bg-glow-2 {
    position: absolute;
    top: 30%;
    right: 10%;
    width: 20rem;
    height: 20rem;
    border-radius: 50%;
    background: rgba(255, 107, 53, 0.04);
    filter: blur(80px);
  }

  .content {
    position: relative;
    z-index: 10;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
  }

  .cta-text {
    flex: 1;
  }

  .icon-box {
    width: 4rem;
    height: 4rem;
    background: #FF6B35;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    color: white;
  }

  h2 {
    font-size: 1.875rem;
    font-weight: 800;
    color: white;
    margin-bottom: 1rem;
  }

  .subtitle {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.125rem;
    margin-bottom: 2.5rem;
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .btn-appstore,
  .btn-google {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-weight: 700;
    padding: 1rem 2rem;
    border-radius: 0.75rem;
    font-size: 1.125rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-appstore {
    background: white;
    color: #1a1a2e;
  }

  .btn-appstore:hover {
    background: #f3f4f6;
    transform: translateY(-1px);
  }

  .btn-google {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-google:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  .note {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.875rem;
    margin-top: 1.5rem;
  }

  .cta-phones {
    display: none;
    position: relative;
    flex-shrink: 0;
  }

  .phone-front-cta {
    position: relative;
    z-index: 2;
  }

  .phone-front-cta :global(.phone-frame) {
    width: 170px;
    box-shadow:
      0 25px 60px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.1);
  }

  .phone-back-cta {
    position: absolute;
    z-index: 1;
    left: -2.5rem;
    top: 1.5rem;
    transform: rotate(-8deg);
  }

  .phone-back-cta :global(.phone-frame) {
    width: 155px;
    opacity: 0.6;
    box-shadow:
      0 20px 50px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 640px) {
    .cta { padding: 7rem 0; }
    h2 { font-size: 2.25rem; }
    .buttons { flex-direction: row; }
  }

  @media (min-width: 768px) {
    .cta-phones {
      display: flex;
      justify-content: center;
    }
  }

  @media (min-width: 1024px) {
    .content {
      flex-direction: row;
      text-align: left;
      gap: 4rem;
    }

    .icon-box {
      margin: 0 0 2rem;
    }

    .subtitle {
      margin-left: 0;
    }

    .buttons {
      justify-content: flex-start;
    }

    .phone-front-cta :global(.phone-frame) {
      width: 190px;
    }

    .phone-back-cta :global(.phone-frame) {
      width: 170px;
    }
  }
</style>
