{
  "expo": {
    "name": "CityGame",
    "slug": "citygame",
    "owner": "jash",
    "scheme": "citygame",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.citygame.mobile",
      "appleTeamId": "H2X8YGN869",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ff6b35"
      },
      "package": "com.citygame.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikacja wymaga dostępu do kamery do skanowania kodów QR i wykonywania zdjęć w zadaniach."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikacja wymaga dostępu do lokalizacji, aby wyświetlać zadania w pobliżu i weryfikować obecność w terenie."
        }
      ],
      [
        "expo-secure-store"
      ],
      [
        "@maplibre/maplibre-react-native",
        {
          "android": {
            "nativeVariant": "opengl"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "wsUrl": "${EXPO_PUBLIC_WS_URL}",
      "eas": {
        "projectId": "af162e07-c480-431d-80d7-d7f074bd4810"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    }
  }
}
