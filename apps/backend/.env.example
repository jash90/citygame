DATABASE_URL="postgresql://citygame:citygame_dev@localhost:5433/citygame"
# Port 5433 and credentials match docker/docker-compose.yml
# Use port 5432 if running Postgres natively without Docker

JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

REDIS_URL="redis://localhost:6380"
# Port 6380 matches docker/docker-compose.yml host mapping (host:6380 → container:6379)
# Use port 6379 if running Redis natively without Docker
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_BUCKET="citygame-assets"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
CORS_ORIGIN="http://localhost:3000"
PORT=3001
