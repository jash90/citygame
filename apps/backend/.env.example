DATABASE_URL="postgresql://citygame:citygame_dev@localhost:5433/citygame"
# Port 5433 and credentials match docker/docker-compose.yml
# Use port 5432 if running Postgres natively without Docker

JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

REDIS_URL="redis://localhost:6380"
# Port 6380 matches docker/docker-compose.yml host mapping (host:6380 → container:6379)
# Use port 6379 if running Redis natively without Docker
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_BUCKET="citygame-assets"
# OpenRouter AI provider (OpenAI-compatible API)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"
# Model to use (see https://openrouter.ai/models for options)
OPENROUTER_MODEL="anthropic/claude-sonnet-4-5"
# Optional: override base URL (defaults to https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Comma-separated list of allowed origins. Supports *.domain.tld wildcards.
# Production example: CORS_ORIGIN="https://citygame-admin.vercel.app,*.vercel.app"
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# Cookie SameSite attribute. In production, defaults to "none" automatically
# for cross-origin cookie support (admin on Vercel + backend on Railway).
# In development, defaults to "lax". Override if needed.
# COOKIE_SAME_SITE=none

PORT=3001
