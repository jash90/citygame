{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "skipLibCheck": true,
    "typeRoots": ["../../node_modules/@types"],
    "types": ["node"],
    "emitDeclarationOnly": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"]
}
